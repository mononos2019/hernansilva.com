---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Hernan Silva',
  description = 'Entrepreneur and technology leader. Co-owner of CIO Landing, a Chicago-area MSP.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <Nav />
  <slot />
  <Footer />
  <script is:inline>
    function toggleMenu() {
      const m = document.getElementById('mobileNav');
      if (m) m.classList.toggle('open');
    }
    function setCaptcha() {
      var a = Math.floor(Math.random() * 9) + 1;
      var b = Math.floor(Math.random() * 9) + 1;
      window._captchaAnswer = a + b;
      var q = document.getElementById('captcha-q');
      if (q) q.textContent = 'what is ' + a + ' + ' + b + '?';
    }
    function handleSubmit() {
      var ci = document.getElementById('captcha-input');
      var ans = ci ? parseInt(ci.value, 10) : NaN;
      if (ans !== window._captchaAnswer) {
        alert('Please answer the verification question correctly.');
        setCaptcha();
        if (ci) ci.value = '';
        return;
      }
      alert('Thank you for your message! Hernan will be in touch soon.');
      setCaptcha();
      if (ci) ci.value = '';
    }
    setCaptcha();
    window.toggleMenu = toggleMenu;
    window.handleSubmit = handleSubmit;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); });
   