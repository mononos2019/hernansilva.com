---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found — Hernan Silva" description="The page you were looking for could not be found." noindex={true}>
  <section class="page-head">
    <div class="section-inner">
      <div class="section-eyebrow">404</div>
      <h2 class="section-title">Page not found</h2>
      <p style="color:var(--text-muted);margin-bottom:2rem;max-width:520px">
        The page you were looking for doesn't exist or may have moved.
      </p>
      <a href="/" class="btn-text">&larr; Back home</a>
    </div>
  </section>
</Base>
