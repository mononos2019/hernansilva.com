      { n: 10, title: 'Administering Microsoft Windows 2000 Directory Services (2148B)', date: 'Apr 2004', desc: 'Microsoft Approved Course — BS Training Center.' },
      { n: 9, title: 'MCP Exam 70-218 Preparation Workshop', date: 'Apr 2004', desc: 'Microsoft Approved Course — BS Training Center.' },
      { n: 8, title: 'Designing a Windows 2000 Directory Services Infrastructure (1561B)', date: 'May 2004', desc: 'Microsoft Approved Course — BS Training Center.' },
      { n: 3, title: 'Windows 2000 Network & Operating System Essentials (2151B)', date: 'May 2004', desc: 'Microsoft Approved Course — BS Training Center.' },
      { n: 5, title: 'Applying Microsoft Security Guidance (Hands-On Lab 2811)', date: 'Aug 2004', desc: 'Microsoft Approved Course — BS Training Center.' },
