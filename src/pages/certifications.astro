---
import Base from '../layouts/Base.astro';

const certs = [
  { name: 'Cybersecurity', issuer: 'Massachusetts Institute of Technology (MIT)', year: '2015' },
  { name: 'CompTIA Security+', issuer: 'CompTIA', year: '2015' },
  { name: 'CompTIA A+', issuer: 'CompTIA', year: '' },
  { name: 'MCSE: Server Infrastructure', issuer: 'Microsoft', year: '' },
  { name: 'Microsoft Certified Professional (MCP)', issuer: 'Microsoft', year: '' },
  { name: 'Cisco Certified Network Associate (CCNA)', issuer: 'Cisco', year: '' },
  { name: 'VMware Certified Professional', issuer: 'VMware', year: '' },
  { name: 'Fortinet Network Security (NSE)', issuer: 'Fortinet', year: '' },
  { name: 'HIPAA Compliance', issuer: 'HIPAA', year: '' },
];
const education = [
  { name: 'B.A., Business Administration', issuer: 'Northeastern University', year: '' },
];
const shield = 'M12 1 3 5v6c0 5.1 3.4 9.3 9 11 5.6-1.7 9-5.9 9-11V5l-9-4zm-1.2 14.2-3.5-3.5 1.4-1.4 2.1 2.1 4.6-4.6 1.4 1.4-6 6z';
---
<Base title="Certifications — Hernan Silva" description="Professional certifications and credentials held by Hernan Silva: MIT Cybersecurity, CompTIA Security+, Cisco CCNA, MCSE, VMware, Fortinet and more.">
  <section class="page-head">
    <div class="section-inner">
      <div class="section-eyebrow">Credentials</div>
      <h2 class="section-title">Certifications</h2>
      <p>Three decades of technical certifications across security, networking, virtualization, and infrastructure.</p>
    </div>
  </section>

  <section>
    <div class="section-inner">
      <div class="cred-grid">
        {certs.map((c) => (
          <div class="cred-card">
            <div class="cred-badge"><svg viewBox="0 0 24 24" aria-hidden="true"><path d={shield}/></svg></div>
            <div class="cred-name">{c.name}</div>
            <div class="cred-issuer">{c.issuer}</div>
            {c.year && <div class="cred-year">Earned {c.year}</div>}
          </div>
        ))}
      </div>

      <h2 class="subhead">Education</h2>
      <div class="cred-grid">
        {education.map((c) => (
          <div class="cred-card">
            <div class="cred-badge"><svg viewBox="0 0 24 24" aria-hidden="true"><path d={shield}/></svg></div>
            <div class="cred-name">{c.name}</div>
            <div class="cred-issuer">{c.issuer}</div>
          </div>
        ))}
      </div>

      <div class="cert-note">
        <p><strong>40+ diplomas and professional certificates on file</strong>, dating back to 1992. Full copies are available on request.</p>
        <a class="btn-primary" href="/#contact">Get in touch</a>
      </div>
    </div>
  </section>
</Base>
