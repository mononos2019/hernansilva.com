      { n: 33, title: 'HP LaserJet 2200 / 2300 (SPN 361)', date: 'Feb 2003', desc: 'HP Service Authorization Certificate.' },
      { n: 21, title: 'HP LaserJet 4200 & 4300 (SPN 375)', date: 'Mar 2003', desc: 'HP Service Authorization Certificate.' },
      { n: 32, title: 'HP LaserJet 4200 & 4300 (SPN 375)', date: 'Mar 2003', desc: 'HP Service Authorization Certificate.' },
      { n: 22, title: 'HP LaserJet 5500 (SPN 366)', date: 'Mar 2003', desc: 'HP Service Authorization Certificate.' },
