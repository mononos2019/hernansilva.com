const totalDocs = groups.reduce((a, g) => a + g.certs.length, 0);
---
<Base title="Certifications — Hernan Silva" description="Professional certifications and credentials held by Hernan Silva: MIT Cybersecurity, CompTIA Security+, Cisco CCNA, MCSE, VMware, Fortinet and more.">
  <section class="page-head">
    <div class="section-inner">
      <div class="section-eyebrow">Credentials</div>
      <h2 class="section-title">Certifications</h2>
      <p>Three decades of technical certifications across security, networking, virtualization, and infrastructure.</p>
    </div>
  </section>

  <section>
    <div class="section-inner">
      <div class="cred-grid">
        {certs.map((c) => (
          <div class="cred-card">
            <div class="cred-name">{c.name}</div>
            <div class="cred-issuer">{c.issuer}</div>
            {c.year && <div class="cred-year">Earned {c.year}</div>}
          </div>
        ))}
      </div>

      <h2 class="subhead">Education</h2>
      <div class="cred-grid">
        {education.map((c) => (
          <div class="cred-card">
            <div class="cred-name">{c.name}</div>
            <div class="cred-issuer">{c.issuer}</div>
          </div>
        ))}
      </div>

      <h2 class="subhead">Certificate Archive</h2>
      <p class="lead">{totalDocs} diplomas and certificates, grouped by issuer and ordered by date. Click any one to view it full size.</p>

      {groups.map((g) => (
        <div class="cert-section">
          <h3 class="cert-group-title">{g.type} <span>{g.certs.length}</span></h3>
          <p class="cert-group-intro">{g.intro}</p>
          <div class="cert-cards">
            {g.certs.map((c) => (
              <div class="cert-doc">
                <img class="cert-doc-img" src={`/images/certs/diploma-${c.n}-thumb.jpg`} data-full={`/images/certs/diploma-${c.n}.jpg`} alt={c.title} decoding="async" onerror="this.closest('.cert-doc').style.display='none'" />
                <div class="cert-doc-body">
                  <div class="cert-doc-meta">{c.date}</div>
                  <div class="cert-doc-title">{c.title}</div>
                  <div class="cert-doc-desc">{c.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}

      <div class="cert-note" style="margin-top:2.75rem">
        <p><strong>Originals available on request.</strong> Spanning training and credentials earned across a 30-year IT career.</p>
        <a class="btn-primary" href="/#contact">Get in touch</a>
      </div>
    </div>
  </section>

  <div class="lightbox" id="lb"><button class="lightbox-close" id="lbclose" aria-label="Close">&times;</button><img id="lbimg" src="" alt="Certificate" /></div>
  <script is:inline>
    (function () {
      var lb = document.getElementById('lb');
      var img = document.getElementById('lbimg');
      document.querySelectorAll('.cert-doc-img').forEach(function (it) {
        it.addEventListener('click', function () { img.src = it.getAttribute('data-full'); lb.classList.add('open'); });
      });
      function close() { lb.classList.remove('open'); img.src = ''; }
      lb.addEventListener('click', function (e) { if (e.target !== img) close(); });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
    })();
  </script>
</Base>
