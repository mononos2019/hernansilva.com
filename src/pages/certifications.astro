---
<Base title="Certifications — Hernan Silva" description="Professional certifications and credentials held by Hernan Silva: MIT Cybersecurity, CompTIA Security+, Cisco CCNA, MCSE, VMware, Fortinet and more.">
  <section class="page-head">
    <div class="section-inner">
      <div class="section-eyebrow">Credentials</div>
      <h2 class="section-title">Certifications</h2>
      <p>Three decades of technical certifications across security, networking, virtualization, and infrastructure.</p>
    </div>
  </section>

  <section>
    <div class="section-inner">
      <div class="cred-grid">
        {certs.map((c) => (
          <div class="cred-card">
            <div class="cred-badge"><svg viewBox="0 0 24 24" aria-hidden="true"><path d={shield}/></svg></div>
            <div class="cred-name">{c.name}</div>
            <div class="cred-issuer">{c.issuer}</div>
            {c.year && <div class="cred-year">Earned {c.year}</div>}
          </div>
        ))}
      </div>

      <h2 class="subhead">Education</h2>
      <div class="cred-grid">
        {education.map((c) => (
          <div class="cred-card">
            <div class="cred-badge"><svg viewBox="0 0 24 24" aria-hidden="true"><path d={shield}/></svg></div>
            <div class="cred-name">{c.name}</div>
            <div class="cred-issuer">{c.issuer}</div>
          </div>
        ))}
      </div>

      <h2 class="subhead">Diplomas & Certificates</h2>
      <p class="lead" style="margin-bottom:1.25rem">A selection of {diplomaIds.length} diplomas and certificates earned since 1992. Click any to enlarge.</p>
      <div class="gallery-grid">
        {diplomaIds.map((_id, i) => (
          <button class="gallery-item" data-full={`/images/certs/diploma-${i + 1}.jpg`} aria-label={`Certificate ${i + 1}`}>
            <img loading="lazy" src={`/images/certs/diploma-${i + 1}-thumb.jpg`} alt={`Certificate ${i + 1}`} width="480" onerror="this.closest('.gallery-item').classList.add('is-broken')" />
          </button>
        ))}
      </div>

      <div class="cert-note" style="margin-top:2.5rem">
        <p><strong>Originals available on request.</strong> The certificates above span training and credentials earned across a 30-year IT career.</p>
        <a class="btn-primary" href="/#contact">Get in touch</a>
      </div>
    </div>
  </section>

  <div class="lightbox" id="lb"><button class="lightbox-close" id="lbclose" aria-label="Close">&times;</button><img id="lbimg" src="" alt="Diploma" /></div>
  <script is:inline>
    (function () {
      var lb = document.getElementById('lb');
      var img = document.getElementById('lbimg');
      document.querySelectorAll('.gallery-item').forEach(function (it) {
        it.addEventListener('click', function () {
          img.src = it.getAttribute('data-full');
          lb.classList.add('open');
        });
      });
      function close() { lb.classList.remove('open'); img.src = ''; }
      lb.addEventListener('click', function (e) { if (e.target !== img) close(); });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
    })();
  </script>
</Base>
