---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, date, category, tags, image, excerpt } = post.data;
const fmt = (d) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const siteUrl = Astro.site ?? new URL('https://hernansilva.com');
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;
const imageUrl = new URL(image, siteUrl).href;

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": excerpt,
  "image": imageUrl,
  "datePublished": date.toISOString(),
  "dateModified": date.toISOString(),
  "url": pageUrl,
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
  "articleSection": category,
  "keywords": tags.join(", "),
  "inLanguage": "en",
  "author": { "@type": "Person", "name": "Hernan Silva", "url": "https://hernansilva.com" },
  "publisher": { "@type": "Person", "name": "Hernan Silva", "url": "https://hernansilva.com" }
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": new URL('/', siteUrl).href },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": new URL('/blog/', siteUrl).href },
    { "@type": "ListItem", "position": 3, "name": title, "item": pageUrl }
  ]
};
---
<Base title={`${title} — Hernan Silva`} description={excerpt} image={image} type="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  </Fragment>

  <article class="article" data-pagefind-body data-pagefind-filter={`category:${category}`}>
    <div class="article-cat">{category}</div>
    <h1>{title}</h1>
    <div class="article-meta">{fmt(date)}</div>
    <img class="article-hero" src={image} alt={title} data-pagefind-meta="image[src]" />
    <div class="article-content">
      <Content />
    </div>
    {tags.length > 0 && (
      <div class="article-tags">
        {tags.map((t) => <span class="article-tag">{t}</span>)}
      </div>
    )}
    <a href="/blog" class="article-back">&larr; Back to all articles</a>
  </article>
</Base>
